# PostgreSQL connection string
# Local:    postgres://postgres:postgres@localhost:5432/shelfstock
# Railway:  copy the "Postgres Connection URL" from your Railway project
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shelfstock

# Secret used to sign JWTs. Generate one with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string

# Port the Express server listens on
PORT=4000

# Comma-separated list of origins allowed to call this API
CORS_ORIGIN=http://localhost:3000
